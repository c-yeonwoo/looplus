{
  "name": "looplus",
  "version": "0.1.0",
  "private": true,
  "description": "Loop+ (루플러스) — 돌수록 더해지는 자산 루프",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/copy-standalone.mjs",
    "start": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "start:next": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.53.0",
    "next": "^15.5.20",
    "pretendard": "1.3.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "22.15.3",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.11",
    "typescript": "5.8.3",
    "vitest": "^3.2.7"
  }
}
