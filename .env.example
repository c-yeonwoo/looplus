# Supabase (선택) — 미설정 시 앱은 localStorage로 동작합니다.
# 로컬: npm run supabase:start 후 `supabase status -o env` 참고. 검증: npm run verify:supabase
NEXT_PUBLIC_SUPABASE_URL=
# 권장: Dashboard API Keys의 publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# 하위호환: legacy anon JWT (eyJ…) — PUBLISHABLE 없을 때만 사용
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 원격 E2E 검증 스크립트용 (앱 런타임에는 넣지 말 것)
# SUPABASE_SERVICE_ROLE_KEY=

# PostHog (선택) — 미설정 시 계측은 no-op. DEV에서는 console.debug.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_ANALYTICS_DEBUG=1

# 온보딩 순서 강제 (선택) — 없으면 sticky A/B (70% 진단먼저)
# NEXT_PUBLIC_ONBOARDING_ORDER=diagnosis_first
# NEXT_PUBLIC_ONBOARDING_ORDER=goals_first

# 리드젠 CTA (선택) — 미설정 시 엔진/홈 CTA는 "곧 연결" + 클릭 계측만.
# Railway: Variables에 넣고 Redeploy (NEXT_PUBLIC_* 는 빌드 시 인라인)
NEXT_PUBLIC_LEAD_URL=
# 도구별 오버라이드 (없으면 LEAD_URL?tool=signal_desk 등)
# NEXT_PUBLIC_LEAD_URL_SIGNAL_DESK=
# NEXT_PUBLIC_LEAD_URL_SIGNAL_APT=
